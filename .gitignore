# ── SARH v4.0 Security-Hardened .gitignore ──
# Strictly excludes credentials, dependencies, and sensitive keys.

# Dependencies (NEVER commit)
/vendor/
/node_modules/

# Environment & Credentials (NEVER commit)
.env
.env.*
!.env.example
/auth.json
/storage/*.key
*.pem
*.key
*.p12
*.pfx

# ── Sensitive Files (added by secure_cleanup.sh) ──
*_key.txt
*_password.*
*_secret.*
*_token.*
*.id_rsa
*.id_ed25519
ssh_config
known_hosts
*_credentials.*
*.keystore

# Security scan reports (local only)
security_scan_report_*.txt

# Laravel Generated
/public/hot
/public/storage
/storage/pail
/.phpunit.cache
.phpunit.result.cache
.phpactor.json

# Build artifacts (tracked for Hostinger — no npm on server)
# /public/build

# IDE & OS
/.fleet
/.idea
/.nova
/.vscode
/.zed
.DS_Store
Thumbs.db
*.swp
*.swo

# Misc
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
